# Database connection configuration (async pgvector driver required)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/railway_ai
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/railway_ai

# Local Ollama service endpoint (used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434

# Directory configs (relative to app directory or absolute paths)
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

# Secret key for JWT signing (generate a secure random key for production)
SECRET_KEY=generate-a-secure-secret-key-here-for-production-use

# ── LLM Provider Configuration ──────────────────────────────────────────────
# Set LLM_PROVIDER to "gemini" to use Google Gemini (cloud, no Ollama needed)
# Set LLM_PROVIDER to "ollama" to use local Ollama (requires Ollama running)
# The system will auto-fallback: primary → secondary → programmatic evaluator
LLM_PROVIDER=gemini

# Google Gemini API key (required when LLM_PROVIDER=gemini)
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model to use (gemini-2.0-flash recommended for speed)
GEMINI_MODEL=gemini-2.0-flash
