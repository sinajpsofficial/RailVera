# Database connection configuration (async pgvector driver required)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/railway_ai
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/railway_ai

# Local Ollama service endpoint
OLLAMA_URL=http://localhost:11434

# Directory configs (relative to app directory or absolute paths)
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

# Secret key for JWT signing (generate a secure random key for production)
SECRET_KEY=generate-a-secure-secret-key-here-for-production-use
